

<!-- Modal -->
<div class="modal fade" id="aiModal" tabindex="-1" role="dialog" aria-labelledby="aiModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="aiModalLabel">{{#str}} aiquestiongenerator, quizaccess_aiquestiongenerator {{/str}}</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <label for="aiDescription">{{#str}} description, quizaccess_aiquestiongenerator {{/str}}</label>
        <textarea id="aiDescription" class="form-control" rows="4"></textarea>
        <div id="aiResponse" class="mt-3 text-success" style="display:none;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">{{#str}} close, quizaccess_aiquestiongenerator {{/str}}</button>
        <button type="button" class="btn btn-primary" id="submitAI" data-loadingtext="{{#str}} loading, quizaccess_aiquestiongenerator {{/str}}">
            {{#str}} submit, quizaccess_aiquestiongenerator {{/str}}
        </button>
      </div>
    </div>
  </div>
</div>


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
